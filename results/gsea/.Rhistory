legend_breaks = c(-2.5, -1.5, -0.5, 0, 0.5),
legend_labels = c("-2.5", "-1.5", "-0.5", "0", "0.5"),
legend_width = 1,
legend_height = 0.5)
heatmap_grob <- ph$gtable
heatmap_with_title <- arrangeGrob(
textGrob("B. RNA vs Protein Log2 Fold Changes",
gp = gpar(fontsize = 12, fontface = "bold")),
heatmap_grob,
ncol = 1,
heights = c(0.08, 1)
)
#######################################
# --- 3. AJUSTE DA PIZZA (Painel C) ---
#######################################
pathway_data_plot <- data.frame(
Pathway = c("Glycolysis", "Muscle contraction", "Other"),
Count = c(7, 1, 1)
)
pie_chart <- ggplot(pathway_data_plot,
aes(x = "", y = Count, fill = Pathway)) +
geom_bar(stat = "identity", width = 1, color = "white") +
coord_polar("y", start = 0) +
scale_fill_manual(values = c("#e74c3c",
"#3498db",
"#95a5a6")) +
labs(title = "C. Functional Classification") +
theme_void(base_size = 14) +
theme(plot.title = element_text(face = "bold"),
legend.position = "bottom")
########################################
# --- 4. MONTAGEM DA FIGURA FINAL ---
########################################
bottom_row <- arrangeGrob(
heatmap_with_title,
pie_chart,
ncol = 2,
widths = c(1.4, 0.9)   # heatmap maior que pizza
)
final_plot <- grid.arrange(
scatter_plot,
bottom_row,
nrow = 2,
heights = c(1.2, 1)
)
ggsave("Figure3_artigo.png",
final_plot,
width = 14,
height = 10,
dpi = 300)
library(pheatmap)
library(ggplotify)
library(cowplot)
library(grid)
library(ggrepel)
###############################################
# --- 1. AJUSTE DO SCATTER PLOT (Painel A) ---
###############################################
cor_test <- cor.test(integration_data$Prot_log2FC,
integration_data$RNA_log2FC,
method = "pearson")
scatter_plot <- ggplot(integration_data,
aes(x = Prot_log2FC, y = RNA_log2FC)) +
geom_hline(yintercept = 0, linetype = "dashed", color = "gray50") +
geom_vline(xintercept = 0, linetype = "dashed", color = "gray50") +
geom_smooth(method = "lm", se = TRUE,
color = "#e74c3c", fill = "#e74c3c", alpha = 0.1) +
geom_point(size = 4, color = "#3498db", alpha = 0.8) +
geom_text_repel(
aes(label = Gene),
size = 3.5,
fontface = "bold",
box.padding = 0.5,
point.padding = 0.4,
force = 2,
max.iter = 5000,
segment.color = "grey40"
) +
annotate("label", x = -2.0, y = 0.18,
label = sprintf("r = %.3f\np = %.4f\nn = 9",
cor_test$estimate,
cor_test$p.value),
fill = "white", fontface = "bold", size = 4) +
labs(x = "Protein log2 Fold Change",
y = "RNA log2 Fold Change",
title = "A. Expression Correlation") +
theme_minimal(base_size = 14) +
theme(panel.border = element_rect(color = "black",
fill = NA,
size = 1),
plot.title = element_text(face = "bold"))
###########################################
# --- 2. AJUSTE DO HEATMAP (Painel B) ---
###########################################
ph <- pheatmap(
t(heatmap_data),
cluster_rows = FALSE,
cluster_cols = TRUE,
color = colorRampPalette(c("#3498db", "white", "#e74c3c"))(100),
breaks = seq(-2.5, 0.5, length.out = 101),
border_color = "black",
cellwidth = 45,
cellheight = 45,
display_numbers = TRUE,
number_format = "%.2f",
fontsize_number = 12,     # 👈 aumenta número
number_color = "black",   # 👈 deixa forte
silent = TRUE,
legend = TRUE,
legend_breaks = c(-2.5, -1.5, -0.5, 0, 0.5),
legend_labels = c("-2.5", "-1.5", "-0.5", "0", "0.5"),
legend_width = 1,
legend_height = 0.5,
legend = TRUE,
legend_position = "bottom")
heatmap_grob <- ph$gtable
heatmap_with_title <- arrangeGrob(
textGrob("B. RNA vs Protein Log2 Fold Changes",
gp = gpar(fontsize = 16, fontface = "bold")),
heatmap_grob,
ncol = 1,
heights = c(0.08, 1)
)
#######################################
# --- 3. AJUSTE DA PIZZA (Painel C) ---
#######################################
pathway_data_plot <- data.frame(
Pathway = c("Glycolysis", "Muscle contraction", "Other"),
Count = c(7, 1, 1)
)
pie_chart <- ggplot(pathway_data_plot,
aes(x = "", y = Count, fill = Pathway)) +
geom_bar(stat = "identity", width = 1, color = "white") +
coord_polar("y", start = 0) +
scale_fill_manual(values = c("#e74c3c",
"#3498db",
"#95a5a6")) +
labs(title = "C. Functional Classification") +
theme_void(base_size = 14) +
theme(plot.title = element_text(face = "bold"),
legend.position = "bottom")
########################################
# --- 4. MONTAGEM DA FIGURA FINAL ---
########################################
bottom_row <- arrangeGrob(
heatmap_with_title,
pie_chart,
ncol = 2,
widths = c(1.6, 0.9)   # heatmap maior que pizza
)
final_plot <- grid.arrange(
scatter_plot,
bottom_row,
nrow = 2,
heights = c(1.2, 1)
)
ggsave("Figure3_artigo.png",
final_plot,
width = 14,
height = 10,
dpi = 300)
